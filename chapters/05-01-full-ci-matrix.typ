$
  lr(chevron.l Psi_0 lr(|hat(H) minus E_0|) Phi_0 chevron.r)
  &= lr(chevron.l Psi_0 lr(|hat(H) minus E_0|))
  (Psi_0
    + sum_(c t) c_c^t Psi_c^t
    + sum_(c lt d\
    t lt u) c_(c d)^(t u) Psi_(c d)^(t u)
    + dots.h)
  chevron.r \
